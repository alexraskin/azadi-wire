---
import Base from '../layouts/Base.astro';
import { getArticles, searchArticles, getArticleSourceNames, getReadDB } from '../lib/db';
import { relativeTime } from '../lib/time';
import { TOPICS, TOPIC_LABELS } from '../lib/types';
import type { Topic } from '../lib/types';

const url = Astro.url;
const currentTopic = url.searchParams.get('topic') || '';
const currentSource = url.searchParams.get('source') || '';
const currentQuery = url.searchParams.get('q')?.trim() || '';
const page = parseInt(url.searchParams.get('page') || '1', 10);

const db = getReadDB((Astro.locals as any).runtime.env);

const isSearching = currentQuery.length > 0;
let articles: any[] = [];
let total = 0;
let pages = 0;
let sourceNames: string[] = [];
let fetchError = false;

try {
  const [result, names] = await Promise.all([
    isSearching
      ? searchArticles(db, currentQuery, { page, limit: 20 })
      : getArticles(db, {
          topic: currentTopic || undefined,
          source: currentSource || undefined,
          page,
          limit: 20,
        }),
    getArticleSourceNames(db),
  ]);
  articles = result.articles;
  total = result.total;
  pages = result.pages;
  sourceNames = names;
} catch {
  fetchError = true;
}

function filterUrl(opts: { topic?: string; source?: string }): string {
  const params = new URLSearchParams();
  const t = opts.topic !== undefined ? opts.topic : currentTopic;
  const s = opts.source !== undefined ? opts.source : currentSource;
  if (t) params.set('topic', t);
  if (s) params.set('source', s);
  const qs = params.toString();
  return qs ? `/?${qs}` : '/';
}

function pageUrl(p: number): string {
  const params = new URLSearchParams();
  if (currentQuery) params.set('q', currentQuery);
  if (!isSearching && currentTopic) params.set('topic', currentTopic);
  if (!isSearching && currentSource) params.set('source', currentSource);
  params.set('page', String(p));
  return `/?${params.toString()}`;
}
---

<Base title={isSearching ? `Search: ${currentQuery}` : 'Feed'}>
  {fetchError ? (
    <div class="error-state">
      <h2>Something went wrong</h2>
      <p>We couldn't load articles right now. Please try again in a moment.</p>
      <a href="/" class="back-link">← Refresh</a>
    </div>
  ) : null}

  {!fetchError && !isSearching && (
    <nav class="topic-filter">
      <a href={filterUrl({ topic: '' })} class:list={['topic-pill', { active: !currentTopic }]}>All</a>
      {TOPICS.filter(t => t !== 'general').map((topic) => (
        <a
          href={filterUrl({ topic })}
          class:list={['topic-pill', { active: currentTopic === topic }]}
        >
          {TOPIC_LABELS[topic]}
        </a>
      ))}
    </nav>
  )}

  {!fetchError && !isSearching && sourceNames.length > 0 && (
    <details class="source-filter-wrap" open={!!currentSource}>
      <summary class="source-filter-toggle">
        {currentSource ? `Source: ${currentSource}` : 'Filter by source'} <span class="chevron">▾</span>
      </summary>
      <nav class="source-filter">
        <a href={filterUrl({ source: '' })} class:list={['source-pill', { active: !currentSource }]}>All sources</a>
        {sourceNames.map((name) => (
          <a
            href={filterUrl({ source: name })}
            class:list={['source-pill', { active: currentSource === name }]}
          >
            {name}
          </a>
        ))}
      </nav>
    </details>
  )}

  {!fetchError && isSearching && (
    <p class="search-results-count">
      {total} result{total !== 1 ? 's' : ''} for "{currentQuery}"
      <a href="/">Clear</a>
    </p>
  )}

  {!fetchError && articles.length === 0 ? (
    <div class="empty-state">{isSearching ? 'No results found.' : 'No articles found.'}</div>
  ) : (
    <ul class="article-list">
      {articles.map((article) => (
        <li class:list={['article-item', { 'has-thumb': !!article.thumbnail_url }]}>
          {article.thumbnail_url && (
            <img
              src={article.thumbnail_url}
              alt=""
              class="article-thumb"
              loading="lazy"
              onerror="this.style.display='none';this.parentElement.classList.remove('has-thumb')"
            />
          )}
          <div class="article-body">
            <h2 class="article-title">
              <a href={`/article/${article.slug || article.id}`}>{article.title}</a>
            </h2>
            <div class="article-meta">
              <span>{article.source_name}</span>
              <span>·</span>
              <span>{relativeTime(article.published_at)}</span>
              <span class="badge">{TOPIC_LABELS[article.topic as Topic] || article.topic}</span>
              <button class="bookmark-btn" data-slug={article.slug || article.id} title="Bookmark">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
              </button>
            </div>
            {article.summary && (
              <p class="article-summary">{article.summary}</p>
            )}
          </div>
        </li>
      ))}
    </ul>
  )}

  {!fetchError && pages > 1 && (
    <div class="pagination">
      {page > 1 ? (
        <a href={pageUrl(page - 1)}>← Previous</a>
      ) : (
        <span class="disabled">← Previous</span>
      )}
      <span>Page {page} of {pages}</span>
      {page < pages ? (
        <a href={pageUrl(page + 1)}>Next →</a>
      ) : (
        <span class="disabled">Next →</span>
      )}
    </div>
  )}

  <script>
    import '../scripts/bookmarks';
  </script>
</Base>
