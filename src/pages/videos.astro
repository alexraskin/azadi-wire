---
import Base from '../layouts/Base.astro';
import { getVideos, getVideoChannelNames, getReadDB } from '../lib/db';
import { relativeTime } from '../lib/time';

const url = Astro.url;
const currentChannel = url.searchParams.get('channel') || '';
const page = parseInt(url.searchParams.get('page') || '1', 10);

const db = getReadDB((Astro.locals as any).runtime.env);

let videos: any[] = [];
let total = 0;
let pages = 0;
let channelNames: string[] = [];
let fetchError = false;

try {
  const [result, names] = await Promise.all([
    getVideos(db, {
      channel: currentChannel || undefined,
      page,
      limit: 12,
    }),
    getVideoChannelNames(db),
  ]);
  videos = result.videos;
  total = result.total;
  pages = result.pages;
  channelNames = names;
} catch {
  fetchError = true;
}

function filterUrl(channel: string): string {
  if (!channel) return '/videos';
  return `/videos?channel=${encodeURIComponent(channel)}`;
}

function pageUrl(p: number): string {
  const params = new URLSearchParams();
  if (currentChannel) params.set('channel', currentChannel);
  params.set('page', String(p));
  return `/videos?${params.toString()}`;
}
---

<Base title="Videos" description="Latest video coverage of Iran from YouTube channels">
  <h1 class="page-title">Videos</h1>

  {fetchError ? (
    <div class="error-state">
      <h2>Something went wrong</h2>
      <p>We couldn't load videos right now. Please try again in a moment.</p>
      <a href="/videos" class="back-link">← Refresh</a>
    </div>
  ) : null}

  {!fetchError && channelNames.length > 0 && (
    <nav class="topic-filter">
      <a href={filterUrl('')} class:list={['topic-pill', { active: !currentChannel }]}>All</a>
      {channelNames.map((name) => (
        <a
          href={filterUrl(name)}
          class:list={['topic-pill', { active: currentChannel === name }]}
        >
          {name}
        </a>
      ))}
    </nav>
  )}

  {!fetchError && videos.length === 0 ? (
    <div class="empty-state">No videos found yet. Check back soon.</div>
  ) : (
    <div class="video-grid">
      {videos.map((video) => (
        <a
          href={`https://www.youtube.com/watch?v=${video.video_id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="video-card"
        >
          <div class="video-thumb-wrap">
            <img
              src={video.thumbnail_url}
              alt={video.title}
              class="video-thumb"
              loading="lazy"
              onerror="this.style.display='none'"
            />
            <div class="video-play-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="video-info">
            <h2 class="video-title">{video.title}</h2>
            <div class="video-meta">
              <span>{video.channel_name}</span>
              <span>·</span>
              <span>{relativeTime(video.published_at)}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}

  {!fetchError && pages > 1 && (
    <div class="pagination">
      {page > 1 ? (
        <a href={pageUrl(page - 1)}>← Previous</a>
      ) : (
        <span class="disabled">← Previous</span>
      )}
      <span>Page {page} of {pages}</span>
      {page < pages ? (
        <a href={pageUrl(page + 1)}>Next →</a>
      ) : (
        <span class="disabled">Next →</span>
      )}
    </div>
  )}
</Base>
