---
import Base from '../layouts/Base.astro';
---

<Base title="RSS Feeds">
  <h1 class="page-title">RSS Feeds</h1>
  <div class="rss-page">
    <p class="rss-intro">
      Subscribe to Azadi Wire in your favorite feed reader. We offer two feeds
      so you can choose the level of coverage that suits you.
    </p>

    <div class="rss-feed-list">
      <div class="rss-feed-card">
        <div class="rss-feed-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
        </div>
        <div class="rss-feed-info">
          <h2 class="rss-feed-name">All Articles</h2>
          <p class="rss-feed-desc">
            Every article from all sources, most recent first. The complete feed
            with up to 50 articles.
          </p>
          <a href="/feed.xml" class="rss-feed-link">
            /feed.xml <span class="rss-feed-copy">→</span>
          </a>
        </div>
      </div>

      <div class="rss-feed-card">
        <div class="rss-feed-icon rss-feed-icon-top">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
        </div>
        <div class="rss-feed-info">
          <h2 class="rss-feed-name">Top Stories</h2>
          <p class="rss-feed-desc">
            Only the most important stories, ranked by AI-assigned importance.
            A curated selection of the top articles from the past 72 hours.
          </p>
          <a href="/top.xml" class="rss-feed-link">
            /top.xml <span class="rss-feed-copy">→</span>
          </a>
        </div>
      </div>
    </div>

    <p class="rss-note">
      Top Stories are selected by AI and may not reflect editorial judgment.
      Copy a feed URL and paste it into your reader to subscribe.
    </p>
  </div>
</Base>
