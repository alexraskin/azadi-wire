---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
}

const SITE_URL = 'https://azadiwire.org';
const DEFAULT_DESC = 'Azadi Wire – Independent Iran news aggregation';
const DEFAULT_IMAGE = `${SITE_URL}/favicon-96x96.png`;

const { title, description, image, ogType } = Astro.props;
const pageTitle = `${title} | Azadi Wire`;
const metaDesc = description || DEFAULT_DESC;
const metaImage = image || DEFAULT_IMAGE;
const metaType = ogType || 'website';
const canonicalUrl = Astro.url.href;
const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:type" content={metaType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:site_name" content="Azadi Wire" />
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDesc} />
    <meta name="twitter:image" content={metaImage} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Azadi Wire" href="/feed.xml" />
    <link rel="alternate" type="application/rss+xml" title="Azadi Wire – Top Stories" href="/top.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="wordmark">Azadi Wire</a>
        <div class="header-right">
          <a href="/digest" class="header-digest" aria-label="Daily Digest">Digest</a>
          <a href="/bookmarks" class="header-bookmarks" aria-label="Bookmarks">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
          </a>
          <form action="/" method="GET" class="search-form" role="search">
          <input
            type="search"
            name="q"
            placeholder="Search..."
            aria-label="Search articles"
            value={Astro.url.searchParams.get('q') || ''}
            autocomplete="off"
            />
          </form>
        </div>
      </div>
    </header>
    <main id="main" class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <nav class="footer-nav" aria-label="Main navigation">
          <a href="/" aria-current={isActive('/') ? 'page' : undefined}>Feed</a>
          <a href="/videos" aria-current={isActive('/videos') ? 'page' : undefined}>Videos</a>
          <a href="/digest" aria-current={isActive('/digest') ? 'page' : undefined}>Digest</a>
          <a href="/subscribe" aria-current={isActive('/subscribe') ? 'page' : undefined}>Newsletter</a>
          <a href="/bookmarks" aria-current={isActive('/bookmarks') ? 'page' : undefined}>Bookmarks</a>
          <a href="/sources" aria-current={isActive('/sources') ? 'page' : undefined}>Sources</a>
          <a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a>
        </nav>
        <p>Azadi Wire – Independent Iran news aggregation</p>
        <p class="footer-links">
          <a href="/rss">RSS</a>
          · <a href="/terms">Terms</a>
          · <a href="https://github.com/alexraskin/azadi-wire" target="_blank" rel="noopener noreferrer">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>
