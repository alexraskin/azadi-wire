---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pageTitle = `${title} | Azadi Wire`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Azadi Wire – Independent Iran news aggregation" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="wordmark">Azadi Wire</a>
        <nav class="site-nav">
          <a href="/">Feed</a>
          <a href="/sources">Sources</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        Azadi Wire – Independent Iran news aggregation
      </div>
    </footer>
  </body>
</html>
