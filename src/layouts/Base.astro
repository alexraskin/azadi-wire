---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const pageTitle = `${title} | Azadi Wire`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Azadi Wire – Independent Iran news aggregation" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="wordmark">Azadi Wire</a>
        <nav class="site-nav">
          <a href="/">Feed</a>
          <a href="/sources">Sources</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <div class="footer-share">
          Share Azadi Wire:
          <a href="https://x.com/intent/tweet?text=Azadi%20Wire%20%E2%80%93%20Independent%20Iran%20news%20aggregation&url=https%3A%2F%2Fazadiwire.org" target="_blank" rel="noopener noreferrer">X</a>
          <a href="https://t.me/share/url?url=https%3A%2F%2Fazadiwire.org&text=Azadi%20Wire%20%E2%80%93%20Independent%20Iran%20news%20aggregation" target="_blank" rel="noopener noreferrer">Telegram</a>
          <a href="https://wa.me/?text=Azadi%20Wire%20%E2%80%93%20Independent%20Iran%20news%20aggregation%20https%3A%2F%2Fazadiwire.org" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="mailto:?subject=Azadi%20Wire&body=Azadi%20Wire%20%E2%80%93%20Independent%20Iran%20news%20aggregation%0A%0Ahttps%3A%2F%2Fazadiwire.org" rel="noopener noreferrer">Email</a>
        </div>
        <p>Azadi Wire – Independent Iran news aggregation · <a href="https://github.com/alexraskin/azadi-wire" target="_blank" rel="noopener noreferrer">GitHub</a></p>
      </div>
    </footer>
  </body>
</html>
